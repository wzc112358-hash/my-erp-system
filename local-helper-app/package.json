{
  "name": "hcz-local-helper-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/electron-main.js",
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts",
    "test": "node --test --experimental-strip-types src/*.test.ts",
    "build": "node scripts/build.mjs",
    "start:electron": "npm run build && electron .",
    "package:win-unpacked": "npm run build && electron-builder --win dir --x64",
    "package:win": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "playwright": "1.60.0"
  },
  "devDependencies": {
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "esbuild": "0.28.0"
  },
  "build": {
    "appId": "cn.henghuacheng.local-helper",
    "productName": "恒化成本地采集助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "HCZ Local Helper",
        "schemes": [
          "hcz-helper"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
